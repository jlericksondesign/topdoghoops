# Public app URL used for generated links.
# For the Vercel demo, use the temporary vercel.app URL first.
# After the domain is connected, use https://topdoghoops.com.
APP_BASE_URL=http://localhost:3000

# Supabase is not connected in the current UI-only demo build.
# Keep these empty until backend wiring starts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend is not connected in the current UI-only demo build.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
